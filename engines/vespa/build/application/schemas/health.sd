schema health {
    document health {
        field post_type_id type string {
            indexing: summary | index | attribute
        }

        field accepted_answer_id type string {
            indexing: summary | index | attribute
        }

        field parent_id type string {
            indexing: summary | index | attribute
        }

        field creation_date type string {
            indexing: summary | index | attribute
        }

        field deletion_date type string {
            indexing: summary | index | attribute
        }

        field score type string {
            indexing: summary | index | attribute
        }

        field view_count type string {
            indexing: summary | index | attribute
        }

        field owner_user_id type string {
            indexing: summary | index | attribute
        }

        field owner_display_name type string {
            indexing: summary | index | attribute
        }

        field last_editor_user_id type string {
            indexing: summary | index | attribute
        }

        field last_editor_display_name type string {
            indexing: summary | index | attribute
        }

        field last_edit_date type string {
            indexing: summary | index | attribute
        }

        field last_activity_date type string {
            indexing: summary | index | attribute
        }

        field tags type string {
            indexing: summary | index | attribute
        }

        field answer_count type string {
            indexing: summary | index | attribute
        }

        field comment_count type string {
            indexing: summary | index | attribute
        }

        field favorite_count type string {
            indexing: summary | index | attribute
        }

        field closed_date type string {
            indexing: summary | index | attribute
        }

        field community_owned_date type string {
            indexing: summary | index | attribute
        }

        field category type string {
            indexing: summary | index | attribute
        }

        field title type string {
            indexing: summary | index | attribute
            match: text
        }

        field body type string {
            indexing: summary | index | attribute
            match: text
        }
    }

    fieldset default {
        fields: title, body
    }

    rank-profile default {
        first-phase {
            expression: bm25(title) + bm25(body)
        }
    }
}