schema products_with_signals_boosts {
    document products_with_signals_boosts {
        field upc type string {
            indexing: summary | index 
            match: text
        }

        field name type string {
            indexing: summary | index 
            match: text
        }

        field short_description type string {
            indexing: summary | index 
            match: text
        }

        field long_description type string {
            indexing: summary | index 
            match: text
        }

        field manufacturer type string {
            indexing: summary | index 
            match: text
        }

        field signals_boosts type weightedset<string> {
            indexing: attribute | summary
        }
    }

    fieldset default {
        fields: name, short_description, long_description, manufacturer
    }

    rank-profile default {
        first-phase {
            expression: max(max(bm25(name) / 2, bm25(long_description) / 2), bm25(manufacturer) / 2)
        }
    }
}