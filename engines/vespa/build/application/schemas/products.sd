schema products {
    document products {
        field upc type string {
            indexing: summary | attribute
            match: text
        }

        field name type string {
            indexing: summary | index
            match: text
        }
        
        field name_fuzzy type string {
            indexing: summary | index
            match: text
        }

        field short_description type string {
            indexing: summary | index 
            match: text
        }

        field long_description type string {
            indexing: summary | index 
            match: text
        }

        field manufacturer type string {
            indexing: summary | index 
            match: text
        }
    }

    fieldset default {
        fields: name, manufacturer, long_description
    }

    rank-profile default {
        first-phase {
            expression: bm25(name) + bm25(long_description) + bm25(manufacturer)
        }
    }
}