schema products {
    document products {
        field upc type string {
            indexing: summary | attribute
            match: text
        }

        field name type string {
            indexing: summary | index
            match: text
            index: enable-bm25
        }
        
        field name_fuzzy type string {
            indexing: summary | index
            match: text
        }

        field short_description type string {
            indexing: summary | index 
            match: text
            index: enable-bm25
        }

        field long_description type string {
            indexing: summary | index 
            match: text
            index: enable-bm25
        }

        field manufacturer type string {
            indexing: summary | index 
            match: text
            index: enable-bm25
        }
    }

    fieldset default {
        fields: name, manufacturer, long_description
    }

    rank-profile default {
        first-phase {            
            expression: max(max(bm25(name) / 2, bm25(long_description) / 2), bm25(manufacturer) / 2)
        }
        summary-features {
            bm25(name)
            bm25(long_description)
            bm25(manufacturer)
        }
    }
}