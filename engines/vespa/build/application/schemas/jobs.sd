schema jobs {
    document jobs {
        field company_country type string {
            indexing: summary | index
        }

        field job_description type string {
            indexing: summary | index
        }

        field company_description type string {
            indexing: summary | index 
        }
    }

    fieldset default {
        fields: job_description, company_description
    }

    rank-profile default {
        first-phase {
            expression: bm25(job_description)
        }
    }
}