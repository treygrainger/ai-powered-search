schema reviews {
    document reviews {
        field id type string {
            indexing: summary | attribute
        }

        field content type string {
            indexing: summary | index | attribute
            match: text
        }

        field categories type string {
            indexing: summary | index | attribute
            match: text
        }

        field doc_type type string {
            indexing: summary | index | attribute
            match: text
        }

        field stars_rating type int {
            indexing: summary | attribute
        }

        field city type string {
            indexing: summary | index | attribute
            match: text
        }

        field state type string {
            indexing: summary | index | attribute
            match: text
        }

        field business_name type string {
            indexing: summary | index | attribute
            match: text
        }

        field name type string {
            indexing: summary | index | attribute
            match: text
        }

        field location_coordinates type position {
            indexing: summary | attribute
        }
    }

    fieldset default {
        fields: content, categories, business_name, name
    }

    rank-profile default {
        first-phase {
            expression: bm25(content, categories, business_name, name)
        }
    }
}