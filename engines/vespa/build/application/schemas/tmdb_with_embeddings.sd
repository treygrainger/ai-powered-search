schema tmdb_with_embeddings {
    document tmdb_with_embeddings {
        field title type string {
            indexing: summary | index | attribute
            match: text
        }

        field movie_id type string {
            indexing: summary | attribute
        }

        field image_id type string {
            indexing: summary | attribute
        }

        field image_embedding type tensor<float>(x[512]) {
            indexing: summary | attribute | index
            attribute {
                distance-metric: innerproduct
            }
            index {
                hnsw {
                    max-links-per-node: 16
                    neighbors-to-explore-at-insert: 200
                }
            }
        }
    }

    fieldset default {
        fields: title
    }

    rank-profile default {
        first-phase {
            expression: nativeRank(title)
        }
    }

    rank-profile vector_similarity {
        inputs {
            query(query_vector) tensor<float>(x[512])
        }
        first-phase {
            expression: closeness(field, image_embedding)
        }
    }

    rank-profile hybrid inherits vector_similarity {
        first-phase {
            expression: nativeRank(title) + closeness(field, image_embedding)
        }
    }
}