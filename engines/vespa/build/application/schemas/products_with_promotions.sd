schema products_with_promotions {
    document products_with_promotions {
        field upc type string {
            indexing: summary | index 
            match: text
        }

        field name type string {
            indexing: summary | index 
            match: text
        }

        field name_fuzzy type string {
            indexing: summary | index
            linguistics {
                profile: luceneNgram
            }
        }
        
        field name_bigram type string {
            indexing: summary | index
            linguistics {
                profile: luceneShingle
            }
        }

        field short_description type string {
            indexing: summary | index 
            match: text
        }
        
        field short_description_bigram type string {
            indexing: summary | index
            linguistics {
                profile: luceneShingle
            }
        }

        field long_description type string {
            indexing: summary | index
            match: text
        }

        field has_promotion type string {
            indexing: summary | index
        }

        field manufacturer type string {
            indexing: summary | index
            match: text
        }
    }

    fieldset default {
        fields: name, short_description, long_description, manufacturer
    }

    rank-profile with_features {
        summary-features {
            bm25(short_description)
            fieldMatch(short_description)
            bm25(long_description)
            fieldMatch(long_description)
            fieldMatch(manufacturer)
            fieldMatch(has_promotion)
            fieldMatch(name)
            fieldMatch(name_fuzzy)
            fieldMatch(name_bigram)
            fieldMatch(short_description_bigram)
        }
    }
}